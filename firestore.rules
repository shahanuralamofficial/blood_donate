rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // হেল্পার ফাংশন: ইউজার লগইন করা আছে কি না চেক করে
    function isSignedIn() {
      return request.auth != null;
    }

    // হেল্পার ফাংশন: ইউজারের নিজের ডাটা কি না চেক করে
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- ইউজার কালেকশন ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && isOwner(userId);

      match /notifications/{notificationId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && isOwner(userId);
      }
    }

    // --- কল (Calls) কালেকশন ---
    match /calls/{callId} {
      allow read, write: if isSignedIn();
    }

    // --- চ্যাট (Chats) কালেকশন ---
    // কল স্ক্রিন থেকে মেসেজ সেভ করার জন্য এই পাথটি ওপেন রাখা প্রয়োজন
    match /chats/{chatId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- ব্লাড রিকোয়েস্ট কালেকশন ---
    match /blood_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.requesterId == request.auth.uid;
    }

    // --- ডাইরেক্ট চ্যাট কালেকশন ---
    match /direct_chats/{chatId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- রক্তদাতা (Donors) কালেকশন ---
    match /donors/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(userId);
    }
  }
}
